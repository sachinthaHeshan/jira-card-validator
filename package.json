{
  "name": "jira-card-validator",
  "version": "1.0.0",
  "description": "CLI tool to validate Jira card statuses against GitHub PR states and auto-transition merged cards",
  "type": "module",
  "bin": {
    "jira-card-validator": "./dist/bin/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "prepare": "npx tsc",
    "build": "tsc",
    "start": "node dist/validateCardStatus.js",
    "dev": "tsx validateCardStatus.ts",
    "configure": "tsx bin/cli.ts configure"
  },
  "keywords": [
    "jira",
    "github",
    "pr",
    "pull-request",
    "validator",
    "cli",
    "devops"
  ],
  "author": "ChameleonCollective",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.5.2",
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
